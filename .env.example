# myRAG application configuration.
# CLI arguments override values from this file.

# MinerU CLI configuration.
# MINERU_EXE: local mineru.exe path.
# MINERU_BACKEND/MINERU_METHOD: MinerU CLI backend flags, currently "-b pipeline -m auto".
# MINERU_OUTPUT_ROOT: root directory where MinerU writes output_root/<pdf_stem>/auto.
MINERU_EXE=
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_MODEL_SOURCE=local
MINERU_OUTPUT_ROOT=documents/output_pipeline

# Source PDF scanning configuration.
# PDF_ROOT: PDF file or directory to scan.
# PDF_RECURSIVE: whether to scan nested directories.
# FORCE_REBUILD: legacy compatibility flag; prefer --pdf-scope all for full PDF processing.
PDF_ROOT=documents/source_documents
PDF_RECURSIVE=true
FORCE_REBUILD=false

# Processed PDF registry and chunk output paths.
# PROCESSED_PDFS_PATH: JSON registry storing PDF MD5 and offline processing state.
# CHUNKS_DIR: directory for final per-document chunk JSON files.
PROCESSED_PDFS_PATH=data/index/processed_pdfs.json
CHUNKS_DIR=data/chunks

# ChromaDB local persistence configuration.
# CHROMA_PERSIST_DIRECTORY: local ChromaDB persistent storage directory.
# CHROMA_COLLECTION_NAME: Chroma collection for RAG chunks.
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=rag_chunks

# Chunk construction defaults.
# INGEST_CHUNK_SIZE/INGEST_CHUNK_OVERLAP: text chunk splitting parameters.
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=120

# Embedding configuration.
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_BATCH_SIZE=8
EMBEDDING_TIMEOUT_SECONDS=120
EMBEDDING_DIMENSION=512

# VLM summary configuration.
# Used to summarize image/table jpg files during offline indexing.
VLM_ENABLED=false
VLM_PROVIDER=openai-compatible
VLM_API_KEY=
VLM_BASE_URL=
VLM_MODEL=
VLM_TIMEOUT_SECONDS=60
VLM_MAX_RETRIES=3
VLM_CACHE_PATH=data/cache/vlm_summaries.json
VLM_MAX_IMAGES_PER_DOC=50

# Online QA configuration.
CHAT_PROVIDER=openai-compatible
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=qwen-plus
CHAT_TIMEOUT_SECONDS=60
CHAT_MAX_RETRIES=3
CHAT_RETRIEVAL_TOP_K=5
CHAT_MAX_CONTEXT_CHARS=6000

# Future service host/port settings.
HOST=127.0.0.1
PORT=8000
